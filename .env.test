# Database Configuration (for testing)
MONGODB_URI=mongodb://localhost:27017/celcat-calendar-test

# Celcat API Configuration
CELCAT_URL=https://celcat.u-bordeaux.fr/Calendar/Home/GetCalendarData
CELCAT_BLACKLIST=["DSPEG","Cours DSPEG"]
CELCAT_REPLACEMENTS={"Test":"💻"}

# Cache Configuration
CACHE_TTL=3600
API_TIMEOUT=6000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret-key

# Log Level (error for tests to reduce noise)
LOG_LEVEL=error

# Test Environment
NODE_ENV=test
