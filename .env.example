# Database Configuration
MONGODB_URI=mongodb://localhost:27017/celcat-calendar

# Celcat API Configuration
CELCAT_URL=https://celcat.u-bordeaux.fr/Calendar/Home/GetCalendarData
CELCAT_BLACKLIST=["DSPEG","Cours DSPEG"]
CELCAT_REPLACEMENTS={"Test":"💻"}

# Cache Configuration
CACHE_TTL=3600
API_TIMEOUT=6000

# Notifications (optional)
NOTIFICATION_WEBHOOK_URL=

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Log Level (info, warn, error)
LOG_LEVEL=info
